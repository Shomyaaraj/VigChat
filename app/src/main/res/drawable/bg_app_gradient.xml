<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/brand_background"
                android:startColor="#F7F4EE" />
        </shape>
    </item>
    <item
        android:gravity="top|end"
        android:height="220dp"
        android:width="220dp">
        <shape android:shape="oval">
            <solid android:color="#1AE7A83D" />
        </shape>
    </item>
    <item
        android:bottom="-48dp"
        android:gravity="bottom|start"
        android:height="180dp"
        android:width="180dp">
        <shape android:shape="oval">
            <solid android:color="#14146C5A" />
        </shape>
    </item>
</layer-list>
