<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel"
            android:paddingLeft="14dp"
            android:paddingTop="8dp"
            android:paddingRight="14dp"
            android:paddingBottom="8dp"
            android:text="@string/share_room_label"
            android:textAppearance="@style/TextAppearance.VigChat.SectionLabel" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/create_room_title"
            android:textAppearance="@style/TextAppearance.VigChat.Hero" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/create_room_subtitle"
            android:textAppearance="@style/TextAppearance.VigChat.Body" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            app:cardUseCompatPadding="true"
            style="@style/Widget.VigChat.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="22dp">

                <ImageView
                    android:id="@+id/qrImage"
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:background="@drawable/bg_panel"
                    android:contentDescription="@string/room_qr_code"
                    android:padding="18dp" />

                <TextView
                    android:id="@+id/roomStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="@string/room_link_placeholder"
                    android:textAppearance="@style/TextAppearance.VigChat.Body" />

                <TextView
                    android:id="@+id/roomLinkText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_panel"
                    android:gravity="center"
                    android:padding="16dp"
                    android:textColor="@color/brand_text"
                    android:textIsSelectable="true"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyLinkBtn"
                        style="@style/Widget.VigChat.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:minHeight="52dp"
                        android:text="@string/copy_link"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/shareLinkBtn"
                        style="@style/Widget.VigChat.Button.Tonal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:minHeight="52dp"
                        android:text="@string/share_link"
                        android:visibility="gone" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/createRoomBtn"
                    style="@style/Widget.VigChat.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:minHeight="56dp"
                    android:text="@string/create_chat_room" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardUseCompatPadding="true"
            style="@style/Widget.VigChat.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/scan_option_title"
                    android:textAppearance="@style/TextAppearance.VigChat.Title" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/scan_option_subtitle"
                    android:textAppearance="@style/TextAppearance.VigChat.Body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/scanBtn"
                    style="@style/Widget.VigChat.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:minHeight="52dp"
                    android:text="@string/scan_qr_instead" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
