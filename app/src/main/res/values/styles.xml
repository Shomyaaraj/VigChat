<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.VigChat.Hero" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">@color/brand_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.VigChat.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/brand_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.VigChat.SectionLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.VigChat.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/brand_text_muted</item>
    </style>

    <style name="Widget.VigChat.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/brand_surface</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="strokeColor">@color/brand_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.VigChat.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_on_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.VigChat.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_outline</item>
        <item name="android:textColor">@color/brand_text</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.VigChat.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/brand_surface_alt</item>
        <item name="android:textColor">@color/brand_text</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.VigChat.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/brand_surface</item>
        <item name="boxCornerRadiusTopStart">22dp</item>
        <item name="boxCornerRadiusTopEnd">22dp</item>
        <item name="boxCornerRadiusBottomStart">22dp</item>
        <item name="boxCornerRadiusBottomEnd">22dp</item>
        <item name="boxStrokeColor">@color/brand_outline</item>
        <item name="hintTextColor">@color/brand_text_muted</item>
    </style>

    <style name="Widget.VigChat.InputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/brand_text</item>
        <item name="android:textColorHint">@color/brand_text_muted</item>
    </style>

</resources>
